# LM Studio Configuration
# Set to 'true' to proxy prompts to LM Studio, or 'false' to load the fine-tuned model locally.
USE_LM_STUDIO=true
LM_STUDIO_IP=localhost
LM_STUDIO_PORT=1234
LM_STUDIO_API_KEY=

