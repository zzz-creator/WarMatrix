# Example env file for ai_server (do NOT commit secrets if any)
# Recommended safe defaults for 6GB GPU systems. Adjust as needed.

# Path to your adapter/checkpoint folder
MODEL_PATH=..\wargame_final_outputs\checkpoint-125

# Loading strategy
LOAD_IN_4BIT=true
USE_8BIT=false
CPU_OFFLOAD=true

# Max GPU memory (GB) to reserve for the model (leave headroom for other workloads)
MAX_GPU_MEMORY_GB=4.0

# Compute dtype for quantized compute: float16 is usually best for 6GB cards
COMPUTE_DTYPE=float16

# During inference, disable KV cache to save VRAM (slower generation)
INFERENCE_USE_CACHE=false

# After each request, release cached allocator memory
EMPTY_CUDA_CACHE_AFTER_REQUEST=true

# LM Studio Configuration
# Toggles between local model (false) and LM Studio proxy (true)
USE_LM_STUDIO=false
LM_STUDIO_IP=192.168.144.11
LM_STUDIO_PORT=1234
LM_STUDIO_API_KEY=
